<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 301 redirects for removed event slugs
  RewriteRule ^events/nuit-blanche/?$ /events/dj-mulukuku-manila [R=301,L]
  RewriteRule ^events/crimson-masquerade/?$ /events [R=301,L]

  # SPA fallback: if request is not an existing file/folder, serve index.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
